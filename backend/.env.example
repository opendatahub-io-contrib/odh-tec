AWS_S3_ENDPOINT=https://my.endpoint.com
AWS_ACCESS_KEY_ID=XXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXX
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
HF_TOKEN=hf_XXXXXXXXXXXXX
MAX_CONCURRENT_TRANSFERS=2
HTTP_PROXY=http://proxy-server:3128
HTTPS_PROXY=http://proxy-server:3128

# ===================================
# Local Storage Configuration
# ===================================

# Comma-separated list of allowed local storage paths
# These paths must exist and be accessible to the application
# Default: /opt/app-root/src/data
LOCAL_STORAGE_PATHS=/opt/app-root/src/data,/opt/app-root/src/models

# Maximum file size for uploads and transfers (in GB)
# Files larger than this limit will be rejected
# Default: 20
MAX_FILE_SIZE_GB=20

# ===================================
# CORS Configuration
# ===================================

# Comma-separated list of allowed origins for production
# Development default: http://localhost:8888,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:8888,http://localhost:3000
# ===================================
# Authentication Configuration
# ===================================

# JWT secret for token signing and verification
# IMPORTANT: Use a strong random string in production (e.g., openssl rand -base64 32)
# This secret is used to sign and verify JWT tokens for API authentication
JWT_SECRET=your-secret-key-change-in-production

